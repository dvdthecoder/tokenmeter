{
  "title": "tokenmeter — LLM Usage",
  "uid": "tokenmeter-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "User",
        "type": "query",
        "datasource": { "uid": "tokenmeter-prometheus" },
        "query": "label_values(tokenmeter_llm_tokens_input_total, user)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "uid": "tokenmeter-prometheus" },
        "query": "label_values(tokenmeter_llm_tokens_input_total, model)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum(increase(tokenmeter_llm_cost_usd_total{user=~\"$user\", model=~\"$model\"}[$__range]))",
          "legendFormat": "Cost"
        }
      ]
    },
    {
      "id": 2,
      "title": "Input Tokens",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum(increase(tokenmeter_llm_tokens_input_total{user=~\"$user\", model=~\"$model\"}[$__range]))",
          "legendFormat": "Input"
        }
      ]
    },
    {
      "id": 3,
      "title": "Output Tokens",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum(increase(tokenmeter_llm_tokens_output_total{user=~\"$user\", model=~\"$model\"}[$__range]))",
          "legendFormat": "Output"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cache Hit Tokens",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum(increase(tokenmeter_llm_tokens_cached_total{user=~\"$user\", model=~\"$model\"}[$__range]))",
          "legendFormat": "Cached"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost over time (USD/hr)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum by (user) (rate(tokenmeter_llm_cost_usd_total{user=~\"$user\", model=~\"$model\"}[5m]) * 3600)",
          "legendFormat": "{{user}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token rate by model (tokens/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum by (model) (rate(tokenmeter_llm_tokens_input_total{user=~\"$user\", model=~\"$model\"}[5m]) * 60)",
          "legendFormat": "{{model}} input"
        },
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum by (model) (rate(tokenmeter_llm_tokens_output_total{user=~\"$user\", model=~\"$model\"}[5m]) * 60)",
          "legendFormat": "{{model}} output"
        }
      ]
    },
    {
      "id": 7,
      "title": "P95 Latency by provider (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(tokenmeter_llm_latency_ms_bucket{user=~\"$user\", model=~\"$model\"}[5m])))",
          "legendFormat": "{{provider}} p95"
        }
      ]
    },
    {
      "id": 8,
      "title": "Cost by user (total)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum by (user) (increase(tokenmeter_llm_cost_usd_total{model=~\"$model\"}[$__range]))",
          "legendFormat": "{{user}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Cost by model (total)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 } },
      "targets": [
        {
          "datasource": { "uid": "tokenmeter-prometheus" },
          "expr": "sum by (model) (increase(tokenmeter_llm_cost_usd_total{user=~\"$user\"}[$__range]))",
          "legendFormat": "{{model}}"
        }
      ]
    }
  ]
}
